<button type="button" class="layui-btn layui-btn-sm add-sort">创建分类</button>
<table id="sort" lay-filter="sort"></table>
<div style="display: none">
    <div class="addSortFrom">
        <div class="layui-form open">
            <div class="layui-form-item">
                <label class="layui-form-label">分类名称</label>
                <div class="layui-input-block">
                    <input type="text" name="content" required lay-verify="required" placeholder="请输入分类名称" autocomplete="off" class="layui-input" />
                </div>
            </div>
            <div class="layui-form-item">
                <div class="layui-input-block">
                    <button class="layui-btn" lay-submit lay-filter="form">创建</button>
                </div>
            </div>
        </div>
    </div>
</div>
