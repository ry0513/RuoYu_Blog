<div class="layui-tab layui-tab-brief" lay-filter="statusTab">
    <ul class="layui-tab-title">
        <li class="layui-this">全部(<span class="status_all"><%= count.all %></span>)</li>
        <li status="2">已发布(<span class="status_release"><%= count.release%></span>)</li>
        <li status="1">审核中(<span class="status_audit"><%= count.audit %></span>)</li>
        <li status="0">草稿箱(<span class="status_draft"><%= count.draft%></span>)</li>
        <li status="3">回收站(<span class="status_recycle"><%= count.recycle %></span>)</li>
    </ul>
</div>

<table id="articleTable" lay-filter="article"></table>
