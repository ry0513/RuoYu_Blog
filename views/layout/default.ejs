<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="<%= RUOYU.description %>" />
        <meta name="keywords" content="<%= RUOYU.keywords %>" />
        <meta name="apple-mobile-web-app-title" content="<%= RUOYU.appTitle %>" />
        <title><%= RUOYU.title %></title>
        <%_ cssList.forEach(item => { _%>
        <link rel="stylesheet" href="/static/<%= item %>.min.css" />
        <%_ }) _%>
    </head>
    <body>
        <%- include(`../pages/${page}`) %>
        <!-- 通用 -->
        <% jsList.forEach(item => { %>
        <script src="/static/<%= item %>.min.js"></script>
        <% }) %>
    </body>
</html>
