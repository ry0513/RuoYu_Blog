<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="<%= RUOYU.description %>" />
        <meta name="keywords" content="<%= RUOYU.keywords %>" />
        <meta name="apple-mobile-web-app-title" content="<%= RUOYU.appTitle %>" />
        <title><%= RUOYU.title %></title>
        <link rel="stylesheet" href="<%= cdnUrl %>/plugin/layui/css/layui.min.css" />
        <link rel="stylesheet" href="<%= cdnUrl %>/plugin/notice/colored-theme.min.css" />
        <%_ cssList.forEach(item => { _%>
        <link rel="stylesheet" href="<%= cdnUrl %>/<%= item %>.min.css" />
        <%_ }) _%>
    </head>
    <body>
        <%- include(`../pages/${page}`) %>
        <script src="<%= cdnUrl %>/plugin/layui/layui.min.js"></script>
        <script src="<%= cdnUrl %>/plugin/qs/qs.min.js"></script>
        <script src="<%= cdnUrl %>/plugin/axios/axios.min.js"></script>
        <script src="<%= cdnUrl %>/plugin/notice/notice.min.js"></script>
        <script src="<%= cdnUrl %>/js/ruoyu/tools.min.js"></script>
        <script src="<%= cdnUrl %>/js/ruoyu/dom.min.js"></script>
        <% jsList.forEach(item => { %>
        <script src="<%= cdnUrl %>/<%= item %>.min.js"></script>
        <% }) %>
    </body>
</html>
